    },
    {
      "name": "skills",
      "label": "Skills",
      "fieldType": "textarea",
      "required": true,
      "placeholder": "Hard Skills (Software, Tools)\nSoft Skills\nLanguages"
    },
    {
      "name": "certifications",
      "label": "Certifications (Optional)",
      "fieldType": "textarea",
      "required": false,
      "placeholder": "Certification Name - Issuing Organization - Year"
    },
    {
      "name": "references",
      "label": "References (Optional)",
      "fieldType": "textarea",
      "required": false,
      "placeholder": "Available upon request OR\nName - Title - Company - Contact Info"
    },
    {
      "name": "document_email",
      "label": "Email (For delivery)",
      "fieldType": "email",
      "required": true
    }
  ],
  "isActive": true,
