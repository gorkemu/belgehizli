  "content": "<div style='font-family: \"Helvetica Neue\", Helvetica, Arial, sans-serif; color: #333; max-width: 800px; margin: auto; padding: 40px; background: #fff; border: 1px solid #eaeaea; box-shadow: 0 4px 10px rgba(0,0,0,0.05);'>\n  <div style='text-align: center; border-bottom: 3px solid #2c3e50; padding-bottom: 20px; margin-bottom: 25px;'>\n    <h1 style='margin: 0; color: #2c3e50; font-size: 2.2em; text-transform: uppercase; letter-spacing: 1px;'>{{ad_soyad}}</h1>\n    <p style='margin: 10px 0 0 0; font-size: 1.05em; color: #555;'>\n      {{adres}}<br/>\n      {{telefon}} &nbsp;|&nbsp; {{email}}\n      {{#if web_sitesi}}<br/>{{web_sitesi}}{{/if}}\n    </p>\n    {{#if dogum_tarihi}}<p style='margin: 5px 0 0 0; font-size: 0.9em; color: #777;'>Doğum Tarihi: {{formatDate dogum_tarihi}}</p>{{/if}}\n  </div>\n\n  {{#if profil_ozeti}}\n  <div style='margin-bottom: 25px;'>\n    <h2 style='color: #2c3e50; font-size: 1.3em; border-bottom: 1px solid #ccc; padding-bottom: 5px; margin-bottom: 10px; text-transform: uppercase;'>Profil Özeti</h2>\n    <p style='margin: 0; line-height: 1.6; text-align: justify;'>{{profil_ozeti}}</p>\n  </div>\n  {{/if}}\n\n  <div style='margin-bottom: 25px;'>\n    <h2 style='color: #2c3e50; font-size: 1.3em; border-bottom: 1px solid #ccc; padding-bottom: 5px; margin-bottom: 10px; text-transform: uppercase;'>İş Deneyimi</h2>\n    <pre style='margin: 0; line-height: 1.6; font-family: inherit; white-space: pre-wrap; word-wrap: break-word;'>{{is_deneyimleri}}</pre>\n  </div>\n\n  <div style='margin-bottom: 25px;'>\n    <h2 style='color: #2c3e50; font-size: 1.3em; border-bottom: 1px solid #ccc; padding-bottom: 5px; margin-bottom: 10px; text-transform: uppercase;'>Eğitim Bilgileri</h2>\n    <pre style='margin: 0; line-height: 1.6; font-family: inherit; white-space: pre-wrap; word-wrap: break-word;'>{{egitim_bilgileri}}</pre>\n  </div>\n\n  <div style='margin-bottom: 25px;'>\n    <h2 style='color: #2c3e50; font-size: 1.3em; border-bottom: 1px solid #ccc; padding-bottom: 5px; margin-bottom: 10px; text-transform: uppercase;'>Yetenekler</h2>\n    <pre style='margin: 0; line-height: 1.6; font-family: inherit; white-space: pre-wrap; word-wrap: break-word;'>{{yetenekler}}</pre>\n  </div>\n\n  {{#if sertifikalar}}\n  <div style='margin-bottom: 25px;'>\n    <h2 style='color: #2c3e50; font-size: 1.3em; border-bottom: 1px solid #ccc; padding-bottom: 5px; margin-bottom: 10px; text-transform: uppercase;'>Sertifikalar ve Kurslar</h2>\n    <pre style='margin: 0; line-height: 1.6; font-family: inherit; white-space: pre-wrap; word-wrap: break-word;'>{{sertifikalar}}</pre>\n  </div>\n  {{/if}}\n\n  {{#if referanslar}}\n  <div style='margin-bottom: 25px;'>\n    <h2 style='color: #2c3e50; font-size: 1.3em; border-bottom: 1px solid #ccc; padding-bottom: 5px; margin-bottom: 10px; text-transform: uppercase;'>Referanslar</h2>\n    <pre style='margin: 0; line-height: 1.6; font-family: inherit; white-space: pre-wrap; word-wrap: break-word;'>{{referanslar}}</pre>\n  </div>\n  {{/if}}\n</div>",
